# Python .gitignore

# Ignore .env files
.env*
.flaskenv*
!.env.project
!.env.vault

# Compiled Python bytecode
__pycache__/
*.py[cod]

# Log files
*.log

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Ignore Claude
.claude

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv


# Virtual environments
.venv
.envrc
